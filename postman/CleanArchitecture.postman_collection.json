          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/Orders/{{orderId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api/{{apiVersion}}", "Orders", "{{orderId}}"]
            },
            "description": "Returns a single OrderDto. 404 if not found."
          },
          "response": []
        },
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var body = pm.response.json();",
                  "    if (body && body.id) {",
                  "        pm.collectionVariables.set('orderId', body.id);",
                  "        console.log('Saved orderId =', body.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Ada Lovelace\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/Orders",
              "host": ["{{baseUrl}}"],
              "path": ["api/{{apiVersion}}", "Orders"]
            },
            "description": "Creates an order. Returns 201 with the created OrderDto. Captures `id` into the orderId variable. `productId` must reference an existing product."
          },
          "response": []
        },
        {
          "name": "Place Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var body = pm.response.json();",
                  "    if (body && body.id) {",
                  "        pm.collectionVariables.set('orderId', body.id);",
                  "        console.log('Saved orderId =', body.id);",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerName\": \"Grace Hopper\",\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/Orders/place",
              "host": ["{{baseUrl}}"],
              "path": ["api/{{apiVersion}}", "Orders", "place"]
            },
            "description": "Places an order (alternate creation flow). Returns 201 with the created OrderDto. Captures `id` into the orderId variable."
          },
          "response": []
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/Orders/{{orderId}}/cancel",
              "host": ["{{baseUrl}}"],
              "path": ["api/{{apiVersion}}", "Orders", "{{orderId}}", "cancel"]
            },
            "description": "Cancels an order. Returns 204 No Content. 400 if the order's state forbids cancellation (DomainException), 404 if not found."
          },
          "response": []
        },
        {
          "name": "Confirm Order",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/{{apiVersion}}/Orders/{{orderId}}/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["api/{{apiVersion}}", "Orders", "{{orderId}}", "confirm"]
            },
            "description": "Confirms an order. Returns 204 No Content. 400 if the order's state forbids confirmation (DomainException), 404 if not found."
          },
          "response": []
        }
      ]
    }
